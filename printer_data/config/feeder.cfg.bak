#[gcode_macro LOAD_ANY_TOOL]

[gcode_macro LOAD_ANY_TOOL]
description: [T<index>] [S<speed>] [D<distane>]
    Unloads the tool specified with distance and speed
    T= Tool number 
    S= Speed of fast reract in mm/s
    D= Distance (length of bowden tube)
variable_purge:             150 #from where you stop the faster feeding to the tip of the nozzle plus a bit for purging
variable_bucket_x:          25 #the x location of you purge bucket
variable_bucket_y:          -4 #the y location of your purge bucket
variable_load_temp:         220 # the temp you load and unload filament at 
variable_dist:              10 #the size of stepps to take towards the extruder
gcode:
    {% if printer.toolhead.homed_axes != "xyz" %}  # checking for homed status 
        RESPOND MSG="Machine not homed. "  
      {% else %}      
        {% if printer.quad_gantry_level.applied|lower == 'false' %} #checking for qgl
            RESPOND MSG="QGL not applied."
           {% else %}
               #if paused should be here
               {%  if printer.toolchanger.tool_number != params.T %} #checking to ensure the correct tool is on the shuttle
                  RESPOND MSG="incorrect tool is active: {printer.toolchanger.tool_number}"
                  T{params.T} #swaping to the correct tool
               {% else %}   
                  RESPOND MSG="correct tool"
               {% endif %}
               M104 S{load_temp}
               #G4 P2000
               G90 ; Absolute pos
               G1 X{bucket_x} Y{bucket_y} Z20 F1800 ; Move over purge bucket
               FILAMENT_FEED T={params.T} S={params.S} MAX={params.D} D={dist}
               M109 S{load_temp}
               M83
               G1 E{purge} F300                   ; extrude 125mm
               G1 E-5 F1800                  ; retract some
               M82                           ; set extruder to absolute
               CLEAN_NOZZLE
               M400                          ; wait for buffer to clear
               M104 S0                       ; Stop heating
               M118 Tool {params.T} loaded
        {% endif %}
    {% endif %}

[gcode_macro LOAD_ANY_TOOL_DIST]
description: [T<index>] [S<speed>] [D<distane>]
    loads the tool specified with distance and speed
    T= Tool number 
    S= Speed of fast reract in mm/s
    D= Distance (length of bowden tube)
variable_purge:              150 #from where you stop the faster feeding to the tip of the nozzle plus a bit for purging
variable_bucket_x:            25 #the x location of you purge bucket
variable_bucket_y:            -4 #the y location of your purge bucket
variable_load_temp:           240 # the temp you load and unload filament at 
gcode:
    {% if printer.toolhead.homed_axes != "xyz" %}  # checking for homed status 
        RESPOND MSG="Machine not homed. Homing all axes."  
      {% else %}      
        {% if printer.quad_gantry_level.applied|lower == 'false' %} #checking for qgl
            RESPOND MSG="QGL not applied."
           {% else %}
               
               {%  if printer.toolchanger.tool_number != params.T %} #checking to ensure the correct tool is on the shuttle
                  RESPOND MSG="incorrect tool is active: {printer.toolchanger.tool_number}"
                  T{params.T} #swaping to the correct tool
               {% else %}   
                  RESPOND MSG="correct tool"
               {% endif %}
               M104 S{load_temp}
               #G4 P2000
               G90 ; Absolute pos
               G1 X{bucket_x} Y{bucket_y} Z20 F1800 ; Move over purge bucket
               FORCE_MOVE STEPPER="extruder_stepper _tool{params.T}_feeder"  DISTANCE={params.D} VELOCITY={params.S} #quick feed to the tool head
               M109 S{load_temp}
               M83
               G1 E{purge} F300                   ; extrude 125mm
               G1 E-5 F1800                  ; retract some
               M82                           ; set extruder to absolute
               CLEAN_NOZZLE
               M400                          ; wait for buffer to clear
               M104 S0                       ; Stop heating
               M118 Tool {params.T} loaded
        {% endif %}
    {% endif %}


[gcode_macro UNLOAD_ANY_TOOL]
description: [T<index>] [S<speed>] [D<distane>]
  Unloads the tool specified with distance and speed
  T= Tool number 
  S= Speed of fast reract in mm/s
  D= Distance (length of bowden tube)
variable_purge:              125 #top of tool head to bottom of nozzle plus purge
variable_bucket_x:            25 #the x location of you purge bucket
variable_bucket_y:            -4 #the y location of your purge bucket
variable_load_temp:           220 # the temp you load and unload filament at   
gcode:
    {% if printer.toolhead.homed_axes != "xyz" %}  # checking for homed status 
        RESPOND MSG="Machine not homed. Homing all axes."  
      {% else %}      
        {% if printer.quad_gantry_level.applied|lower == 'false' %} #checking for qgl
            RESPOND MSG="QGL not applied."
           {% else %}
               
               {%  if printer.toolchanger.tool_number != params.T %} #checking to ensure the correct tool is on the shuttle
                  RESPOND MSG="incorrect tool is active: {printer.toolchanger.tool_number}"
                  T{params.T} #swaping to the correct tool
               {% else %}   
                  RESPOND MSG="correct tool"
                  G4 P2000
               {% endif %}

               M104 S{load_temp}
               G90 ; Absolute pos
               G1 X{bucket_x} Y{bucket_y} Z20 F1800 ; Move over purge bucket
               M109 S{load_temp}
               M83
               G1 E1 F200                  ; retract some
               G1 E-{purge} F300                   ; extrude 125mm
               M82                           ; set extruder to absolute
               M400                          ; wait for buffer to clear
               FORCE_MOVE STEPPER="extruder_stepper _tool{params.T}_feeder"  DISTANCE=-{params.D} VELOCITY={params.S} #quick feed to the tool head
               M104 S0                       ; Stop heating
               M118 Tool {params.T} unloaded
        {% endif %}
    {% endif %}




[gcode_macro FILAMENT_FEED]
description: "Feeds filament with FORCE_MOVE until the filament sensor switch triggers"
# Params:
#   T = Tool number
#   S = Speed (mm/s)
#   D = Step distance (mm)
#   MAX = Maximum distance (override)
variable_dist: 10
variable_max_dist: 1500
variable_speed: 10
variable_moved: 0
#variable_triggered: 0

gcode:
    {% set T = params.T|default(0)|int %}
    {% set speed = params.S|default(speed)|float %}
    {% set dist = params.D|default(dist)|float %}
    {% set max_dist = params.MAX|default(max_dist)|float %}
    {% set sensor = "filament_switch_sensor filament_sensor_at_tool%s" % T %}
    
    # Reset state
    SET_GCODE_VARIABLE MACRO=FILAMENT_FEED VARIABLE=moved VALUE=0
    #SET_GCODE_VARIABLE MACRO=FILAMENT_FEED VARIABLE=triggered VALUE=0

    RESPOND MSG="Tool {T}: Feeding filament until sensor triggers"
    
    QUERY_FILAMENT_SENSOR SENSOR=filament_sensor_at_tool{T}
    {% if printer[sensor].filament_detected %}
        RESPOND MSG="Tool {T}: Filament already at sensor"
        #SET_GCODE_VARIABLE MACRO=FILAMENT_FEED VARIABLE=triggered VALUE=1
        {% else %}
            FORCE_MOVE STEPPER="extruder_stepper _tool{T}_feeder"  DISTANCE={max_dist * 0.5} VELOCITY={speed} #quick feed to the tool head
            RESPOND MSG="filament not present starting feed loop"
            _FILAMENT_FEED_STEP T={T} S={speed} D={dist} MAX={max_dist}
        {% endif %}    
   
    #SET_GCODE_VARIABLE MACRO=FILAMENT_FEED VARIABLE=triggered VALUE=0

# much better
#button https://www.digikey.ca/en/products/detail/same-sky-formerly-cui-devices/TS03-66-80-BK-160-LCR-D-67/15634304