[mcu feeder]
serial: /dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_0001-if00-port0


[belay tool0_belay]
extruder_type: extruder_stepper
extruder_stepper_name: _tool0_feeder
sensor_pin: !feeder:PD3
multiplier_high: 1.05
multiplier_low: 0.95
debug_level: 1

[belay tool1_belay]
extruder_type: extruder_stepper
extruder_stepper_name: _tool1_feeder
sensor_pin: !feeder:PJ0
multiplier_high: 1.05
multiplier_low: 0.95
debug_level: 1

[belay tool2_belay]
extruder_type: extruder_stepper
extruder_stepper_name: _tool2_feeder
sensor_pin: !feeder:PJ1
multiplier_high: 1.05
multiplier_low: 0.95
debug_level: 1

[belay tool3_belay]
extruder_type: extruder_stepper
extruder_stepper_name: _tool3_feeder
sensor_pin: !feeder:PE4
multiplier_high: 1.05
multiplier_low: 0.95
debug_level: 1

[belay tool4_belay]
extruder_type: extruder_stepper
extruder_stepper_name: _tool4_feeder
sensor_pin: !feeder:PE5
multiplier_high: 1.05
multiplier_low: 0.95
debug_level: 1

[gcode_button t0_unload_button] #button for unloading tool 0
pin: ^!feeder:PD2
press_gcode:
    UNLOAD_ANY_TOOL T=0 D=1400 S=30
    #RESPOND MSG="unload tool0"

[gcode_button t1_unload_button] #button for unloading tool 4
pin: !feeder:PK4
press_gcode:
    UNLOAD_ANY_TOOL T=1 D=1400 S=30
    #RESPOND MSG="unload tool1"

[gcode_button t2_unload_button] #button for unloading tool 4
 pin: !feeder:PK7
 press_gcode:
     UNLOAD_ANY_TOOL T=2 D=1400 S=30
     #RESPOND MSG="unload tool1"

[gcode_button t3_unload_button] #button for unloading tool 4
pin: !feeder:PK6
press_gcode:
    UNLOAD_ANY_TOOL T=3 D=1400 S=30
    #RESPOND MSG="unload tool3"

[gcode_button t4_unload_button] #button for unloading tool 4
pin: !feeder:PK5
press_gcode:
    UNLOAD_ANY_TOOL T=4 D=1400 S=30
    #RESPOND MSG="unload tool4"

[extruder_stepper _tool0_feeder]
extruder: extruder
step_pin: feeder:PF0
dir_pin:  feeder:PF1
enable_pin: !feeder:PD7
microsteps: 16
full_steps_per_rotation: 200
gear_ratio: 50:17
rotation_distance: 22.319100012672


[tmc2208 extruder_stepper _tool0_feeder]
uart_pin: feeder:PG5
run_current: .5
hold_current: .05
stealthchop_threshold: 250

[extruder_stepper _tool1_feeder]
extruder: extruder1
step_pin: feeder:PF6
dir_pin: feeder:PF7
enable_pin: !feeder:PF2
microsteps: 16
full_steps_per_rotation: 200
gear_ratio: 50:17
rotation_distance: 22.319100012672

[tmc2208 extruder_stepper _tool1_feeder]
uart_pin: feeder:PE3
run_current: .5
hold_current: .05
stealthchop_threshold: 250

[extruder_stepper _tool2_feeder]
extruder: extruder2
step_pin: feeder:PL3
dir_pin:  feeder:PL1
enable_pin: !feeder:PK0
microsteps: 16
full_steps_per_rotation: 200
gear_ratio: 50:17
rotation_distance: 22.319100012672

[tmc2208 extruder_stepper _tool2_feeder]
uart_pin: feeder:PH3
run_current: .5
hold_current: .05
stealthchop_threshold: 250

[extruder_stepper _tool3_feeder]
extruder: extruder3
step_pin: feeder:PA4
dir_pin: !feeder:PA6
enable_pin: !feeder:PA2
microsteps: 16
full_steps_per_rotation: 200
gear_ratio: 50:17
rotation_distance: 22.319100012672 #23.13253012


[tmc2208 extruder_stepper _tool3_feeder]
uart_pin: feeder:PB5
run_current: .5
hold_current: .05
stealthchop_threshold: 250


[extruder_stepper _tool4_feeder]
